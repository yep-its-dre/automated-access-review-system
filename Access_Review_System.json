    {
      "parameters": {
        "jsCode": "const findings = $('Compare Access Against Policy').all().map(item => item.json);\n\n  const orphaned = findings.filter(f => f.Flag === 'Orphaned Account').length;\n  const overProvisioned = findings.filter(f => f.Flag === 'Over-Provisioned').length;\n  const elevated = findings.filter(f => f.Flag === 'Elevated Access').length;\n  const stale = findings.filter(f => f.Flag.startsWith('Stale')).length;\n  const total = findings.length;\n\n  const summary = '*Access Review Completed — ' + new Date().toISOString().split('T')[0] + '*\\n\\n' +\n    '*Findings Summary:*\\n' +\n    '• Orphaned Accounts: ' + orphaned + '\\n' +\n    '• Over-Provisioned: ' + overProvisioned + '\\n' +\n    '• Elevated Access: ' + elevated + '\\n' +\n    '• Stale Accounts (90+ days): ' + stale + '\\n\\n' +\n    '*Total Flags Requiring Action: ' + total + '*\\n\\n' +\n    'Full report available in the Access Review Report tab.';\n\n  return [{ json: { summary: summary } }];"
      },
