    {
      "parameters": {
        "jsCode": "// Pull data from all three Google Sheets reads\n  const employees = $('Read Employee Directory').all().map(item => item.json);\n  const accessRecords = $('Read Access Matrix').all().map(item => item.json);\n  const policies = $('Read Access Policy').all().map(item => item.json);\n\n  const today = new Date();\n  const reviewDate = today.toISOString().split('T')[0];\n  const staleThreshold = 90;\n  const findings = [];\n\n  // Build employee lookup by email\n  const employeeMap = {};\n  for (const emp of employees) {\n    employeeMap[emp.Email] = emp;\n  }\n\n  // Build policy lookup by department + role + app\n  const policyMap = {};\n  for (const pol of policies) {\n    const key = pol.Department + '|' + pol.Role + '|' + pol.App;\n    policyMap[key] = pol['Expected Access'];\n  }\n\n  // Analyze each access record\n  for (const record of accessRecords) {\n    const email = record['Employee Email'];\n    const employee = employeeMap[email];\n    if (!employee) continue;\n\n    const app = record.App;\n    const currentAccess = record['Access Level'];\n    const lastLogin = new Date(record['Last Login']);\n    const daysSinceLogin = Math.floor((today - lastLogin) / (1000 * 60 * 60 * 24));\n    const policyKey = employee.Department + '|' + employee.Role + '|' + app;\n    const expectedAccess = policyMap[policyKey];\n\n    // Check 1: Orphaned account (departed employee still has access)\n    if (employee.Status === 'Departed') {\n      findings.push({\n        'Review Date': reviewDate,\n        'Employee': employee.Name,\n        'Email': email,\n        'Department': employee.Department,\n        'App': app,\n        'Current Access': currentAccess,\n        'Expected Access': 'None (Departed)',\n        'Flag': 'Orphaned Account',\n        'Reviewer': 'Automated',\n        'Action Taken': 'Pending Review',\n        'Action Date': ''\n      });\n      continue;\n    }\n\n    // Check 2: Over-provisioned (has access to app their role should not have)\n    if (expectedAccess === 'None') {\n      findings.push({\n        'Review Date': reviewDate,\n        'Employee': employee.Name,\n        'Email': email,\n        'Department': employee.Department,\n        'App': app,\n        'Current Access': currentAccess,\n        'Expected Access': 'None',\n        'Flag': 'Over-Provisioned',\n        'Reviewer': 'Automated',\n        'Action Taken': 'Pending Review',\n        'Action Date': ''\n      });\n      continue;\n    }\n\n    // Check 3: Elevated access (Admin when policy says User)\n    if (currentAccess === 'Admin' && expectedAccess === 'User') {\n      findings.push({\n        'Review Date': reviewDate,\n        'Employee': employee.Name,\n        'Email': email,\n        'Department': employee.Department,\n        'App': app,\n        'Current Access': 'Admin',\n        'Expected Access': 'User',\n        'Flag': 'Elevated Access',\n        'Reviewer': 'Automated',\n        'Action Taken': 'Pending Review',\n        'Action Date': ''\n      });\n    }\n\n    // Check 4: Stale account (no login in 90+ days)\n    if (daysSinceLogin > staleThreshold) {\n      findings.push({\n        'Review Date': reviewDate,\n        'Employee': employee.Name,\n        'Email': email,\n        'Department': employee.Department,\n        'App': app,\n        'Current Access': currentAccess,\n        'Expected Access': expectedAccess || currentAccess,\n        'Flag': 'Stale Account (' + daysSinceLogin + ' days)',\n        'Reviewer': 'Automated',\n        'Action Taken': 'Pending Review',\n        'Action Date': ''\n      });\n    }\n  }\n\n  return findings.map(f => ({ json: f }));"
      },
